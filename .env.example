# 数据库密码
DB_PASSWORD=change_this_to_a_secure_password

# 管理员初始账户
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_to_a_secure_password

# JWT 密钥（至少32个字符）
JWT_SECRET=change_this_to_a_random_32_char_secret

# HTTPS模式: http / selfsigned / letsencrypt
HTTPS_MODE=selfsigned

# 域名（letsencrypt模式需要）
DOMAIN=localhost

# 服务端口
PORT=8443